# ════════════════════════════════════════════════════════════════════════════
#  EchoTube — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════════════

# ── BACKEND (set on Render → Environment) ────────────────────────────────────

# Port the server listens on (Render sets this automatically)
PORT=3000

# Your deployed Vercel frontend URL — required for CORS
# Example: https://echo-tube-mocha.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# Google YouTube Data API v3 key — optional but speeds up /api/info calls
# Get one at: https://console.cloud.google.com
YOUTUBE_API_KEY=

# YouTube session cookies as raw text (Netscape format)
# Paste the contents of your cookies.txt here to bypass bot detection
# on serverless/cloud environments (Render, Railway, etc.)
YOUTUBE_COOKIES=

# ── FRONTEND (set on Vercel → Settings → Environment Variables) ──────────────

# Your Render backend URL — REQUIRED, must NOT have a trailing slash
# Example: https://echoutube-api.onrender.com
VITE_API_BASE_URL=https://your-render-backend.onrender.com
